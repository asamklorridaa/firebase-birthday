---
import svgPinkStar from "../assets/pink-star.svg";
---

<div class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,0.3)] relative p-10 mt-10">
  <h2 class="text-3xl font-medium">Unggah Momenmu</h2>
  <p class="text-lg max-w-lg mx-auto">
    Bagikan foto terbaik atau momen tak terlupakan bersama Saniya (Maksimal 5MB)
  </p>
  
  <form class="flex flex-col gap-4 mt-6 text-left relative z-10" id="gallery-form">
    <div class="flex flex-col gap-2">
      <label for="gallery-name" class="font-bold text-lg">Nama Pengirim</label>
      <input 
        type="text" 
        id="gallery-name" 
        name="name" 
        placeholder="Masukkan namamu" 
        class="border-3 border-black p-3 outline-none focus:bg-[var(--yellow)] transition-colors w-full rounded-none"
        required
      />
    </div>
    
    <div class="flex flex-col gap-2">
      <label for="gallery-image" class="font-bold text-lg">Pilih Foto</label>
      <input 
        type="file" 
        id="gallery-image" 
        name="image" 
        accept="image/*"
        class="border-3 border-black p-3 outline-none focus:bg-[var(--yellow)] transition-colors w-full rounded-none cursor-pointer bg-white file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-2 file:border-black file:text-sm file:font-semibold file:bg-[var(--yellow)] hover:file:bg-black hover:file:text-white file:transition-colors file:cursor-pointer"
        required
      />
      <p class="text-sm opacity-80" id="file-info">Maksimal 5MB</p>
    </div>

    <div class="flex flex-col gap-2">
      <label for="gallery-caption" class="font-bold text-lg">Caption (Opsional)</label>
      <textarea 
        id="gallery-caption" 
        name="caption" 
        rows="2" 
        placeholder="Berikan sedikit cerita tentang foto ini..." 
        class="border-3 border-black p-3 outline-none focus:bg-[var(--yellow)] transition-colors resize-none w-full rounded-none"
      ></textarea>
    </div>

    <button 
      type="submit" 
      class="bg-[var(--blue)] text-black font-bold text-lg border-3 border-black py-3 mt-4 transition-all hover:opacity-80 flex items-center justify-center gap-2 rounded-full cursor-pointer relative"
    >
      Unggah Foto <i class="ri-upload-2-fill"></i>
    </button>
  </form>
  
  <img
    src={svgPinkStar.src}
    alt="svg"
    width="80"
    class="absolute -bottom-10 -left-10"
  />
</div>

<script>
  import { db } from "../lib/firebase";
  import { collection, addDoc } from "firebase/firestore";

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('gallery-form') as HTMLFormElement;
    const fileInput = document.getElementById('gallery-image') as HTMLInputElement;
    const fileInfo = document.getElementById('file-info');

    if (!form || !fileInput) return;

    // Submit on Enter (Shift+Enter for newline)
    const captionInput = document.getElementById('gallery-caption') as HTMLTextAreaElement;
    captionInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    // Validasi file maksimal 5MB sebelum di-upload
    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) {
        if (file.size > 5 * 1024 * 1024) {
          alert("Ukuran file terlalu besar! Maksimal 5MB.");
          fileInput.value = ""; // Reset form input
          if (fileInfo) {
              fileInfo.textContent = "File ditolak (Terlalu besar). Pilih file lain.";
              fileInfo.classList.add("text-red-500");
          }
        } else {
          if (fileInfo) {
             fileInfo.textContent = `File terpilih: ${file.name} (${(file.size / (1024 * 1024)).toFixed(2)} MB)`;
             fileInfo.classList.remove("text-red-500");
          }
        }
      }
    });

    // Fungsi kompresi gambar HTML5 Canvas
    const compressImage = (file: File): Promise<string> => {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.readAsDataURL(file);
        reader.onload = (event) => {
          const img = new Image();
          img.src = event.target?.result as string;
          img.onload = () => {
            const canvas = document.createElement("canvas");
            const MAX_WIDTH = 1000;
            const MAX_HEIGHT = 1000;
            let width = img.width;
            let height = img.height;

            if (width > height) {
              if (width > MAX_WIDTH) {
                height *= MAX_WIDTH / width;
                width = MAX_WIDTH;
              }
            } else {
              if (height > MAX_HEIGHT) {
                width *= MAX_HEIGHT / height;
                height = MAX_HEIGHT;
              }
            }

            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext("2d");
            ctx?.drawImage(img, 0, 0, width, height);
            
            // Kompresi ke JPEG dengan kualitas 70% agar ukurannya jauh lebih kecil
            const dataUrl = canvas.toDataURL("image/jpeg", 0.7);
            resolve(dataUrl);
          };
          img.onerror = (err) => reject(err);
        };
        reader.onerror = (err) => reject(err);
      });
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;
      
      const file = fileInput.files?.[0];
      if (!file) {
        alert("Pilih foto terlebih dahulu.");
        return;
      }

      submitBtn.innerHTML = 'Memproses & Mengunggah... <i class="ri-loader-4-line animate-spin"></i>';
      submitBtn.disabled = true;

      try {
        const formData = new FormData(form);
        const name = formData.get('name') as string;
        const caption = formData.get('caption') as string;
        
        // Kompresi gambar menjadi base64 string
        const base64Image = await compressImage(file);

        // Upload string base64 langsung ke Firebase
        await addDoc(collection(db, "gallery"), {
          sender: name,
          caption: caption,
          image: base64Image,
          likes: 0,
          created_at: new Date().toISOString()
        });
        
        form.reset();
        if (fileInfo) {
            fileInfo.textContent = "Maksimal 5MB";
            fileInfo.classList.remove("text-red-500");
        }
        
        // Feedback visual sederhana
        submitBtn.innerHTML = 'Berhasil! <i class="ri-check-line"></i>';
        setTimeout(() => {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }, 3000);
      } catch (error) {
        console.error("Error adding document: ", error);
        alert('Gagal mengunggah foto. Pastikan ukuran file atau koneksi internet Anda stabil.');
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      }
    });
  });
</script>
