---
import svgNew from "../assets/new.svg";
import FormGallery from "./FormGallery.astro";
---
<section id="gallery" class="py-20">
  <div class="max-w-4xl mx-auto pb-20 px-10 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="flex relative">
        <h1 class="text-3xl">
          Here's what our moments!
        </h1>
        <img
          src={svgNew.src}
          alt="arrow"
          width="40"
          class="absolute -right-3 md:-right-10 bottom-0"
        />
      </div>
    </div>

    <!-- Container for dynamic gallery from Supabase -->
    <div id="gallery-container"class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 mt-8">
      <!-- Loading state -->
      <div class="col-span-1 md:col-span-2 lg:col-span-2 text-center py-10">
        <p class="animate-pulse text-lg font-bold">Memuat galeri...</p>
      </div>
    </div>
    
    <div class="mt-20">
      <FormGallery />
    </div>
  </div>
</section>

<script>
  import { db } from "../lib/firebase";
  import { collection, query, orderBy, onSnapshot, doc, getDoc, updateDoc } from "firebase/firestore";

  // Helper function to render gallery items
  function renderGallery(items: any[], container: HTMLElement) {
    container.innerHTML = ""; // Bersihkan loading atau data lama

    if (items.length === 0) {
      container.innerHTML = `<p class="col-span-1 md:col-span-2 lg:col-span-2 text-center py-10">Belum ada foto. Jadilah yang pertama mengunggah!</p>`;
      return;
    }

    items.forEach((data) => {
      const id = data.id;
      
      // Format waktu
      let timeString = "";
      if (data.created_at) {
        const date = new Date(data.created_at);
        const day = date.getDate();
        const month = date.toLocaleString('id-ID', { month: 'short' });
        const year = date.getFullYear();
        const hours = date.getHours().toString().padStart(2, '0');
        const minutes = date.getMinutes().toString().padStart(2, '0');
        timeString = `${day} ${month} ${year} ${hours}:${minutes}`;
      }

      // Setup Like dari LocalStorage dan Supabase
      let totalLikes = data.likes || 0;
      let isLiked = localStorage.getItem(id + "-galleryIsLiked") === "true";

      const card = document.createElement("div");
      card.className = "flex flex-col bg-white p-5 group relative transition-all duration-200 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)]";
      
      card.innerHTML = `
        <div class="w-full h-[300px] md:h-[400px] overflow-hidden border-2">
          <img src="${data.image}" alt="Foto" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
        </div>
        <div class="space-y-1 pt-4 flex flex-col justify-between flex-1">
          <div class="flex justify-between items-start">
            <div>
              <h2 class="text-xl font-medium">${data.sender || "Anonim"}</h2>
              <p class="text-sm opacity-80">${timeString}</p>
            </div>
            <button class="gallery-like-btn flex items-center gap-1 border-2 border-black px-3 py-1 rounded-full hover:bg-[var(--yellow)] transition-colors active:translate-y-1 z-10 cursor-pointer" data-id="${id}">
              <i class="ri-heart-3-${isLiked ? 'fill text-red-500' : 'line'} text-lg heart-icon"></i>
              <span class="like-count font-bold text-sm">${totalLikes}</span>
            </button>
          </div>
          ${data.caption ? `<p class="mt-4 italic">"${data.caption}"</p>` : ''}
        </div>
        
        <!-- Bars dari Bars.astro -->
        <div class="absolute left-[50%] bottom-0 -translate-x-[50%] border-b-3 w-[105%] rounded-full pointer-events-none"></div>
        <div class="absolute left-[50%] top-0 -translate-x-[50%] border-b-3 w-[105%] rounded-full pointer-events-none"></div>
        <div class="absolute left-0 -bottom-2 border-l-3 h-[105%] rounded-full pointer-events-none"></div>
        <div class="absolute right-0 -bottom-2 border-r-3 h-[105%] rounded-full pointer-events-none"></div>
      `;

      container.appendChild(card);
    });

    // Pasang event listener untuk tombol like
    const likeButtons = container.querySelectorAll(".gallery-like-btn");
    likeButtons.forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        const btnId = btn.getAttribute("data-id");
        const countSpan = btn.querySelector(".like-count");
        const icon = btn.querySelector(".heart-icon");

        if (!btnId) return;

        let currentIsLiked = localStorage.getItem(btnId + "-galleryIsLiked") === "true";

        try {
          if (!currentIsLiked) {
            icon?.classList.remove("ri-heart-3-line");
            icon?.classList.add("ri-heart-3-fill", "text-red-500");
            if (countSpan) countSpan.textContent = (parseInt(countSpan.textContent || '0') + 1).toString();
            
            localStorage.setItem(btnId + "-galleryIsLiked", "true");
            
            const docRef = doc(db, "gallery", btnId);
            const docSnap = await getDoc(docRef);
            if (docSnap.exists()) {
              const currentLikes = docSnap.data().likes || 0;
              await updateDoc(docRef, { likes: currentLikes + 1 });
            }
          } else {
            icon?.classList.remove("ri-heart-3-fill", "text-red-500");
            icon?.classList.add("ri-heart-3-line");
            if (countSpan) countSpan.textContent = (parseInt(countSpan.textContent || '1') - 1).toString();
            
            localStorage.setItem(btnId + "-galleryIsLiked", "false");
            
            const docRef = doc(db, "gallery", btnId);
            const docSnap = await getDoc(docRef);
            if (docSnap.exists()) {
              const currentLikes = docSnap.data().likes || 1;
              await updateDoc(docRef, { likes: Math.max(currentLikes - 1, 0) });
            }
          }
        } catch (error) {
          console.error("Gagal update like:", error);
        }
      });
    });
  }

  document.addEventListener("DOMContentLoaded", async () => {
    const container = document.getElementById("gallery-container");
    if (!container) return;

    const q = query(collection(db, "gallery"), orderBy("created_at", "desc"));

    // Subscribe to realtime changes (menangani initial fetch juga)
    onSnapshot(q, (snapshot) => {
      const items = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      }));
      renderGallery(items, container);
    }, (error) => {
      console.error("Error fetching gallery:", error);
      container.innerHTML = `<p class="col-span-1 md:col-span-2 lg:col-span-2 text-center py-10">Gagal memuat galeri.</p>`;
    });
  });
</script>
